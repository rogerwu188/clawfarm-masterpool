{
  "name": "clawfarm_attestation",
  "version": "0.1.0-draft",
  "phase": "phase1",
  "accepted_values": {
    "proof_mode": ["sig_log"],
    "usage_basis": ["provider_reported"],
    "signature_scheme": "ed25519"
  },
  "constants": {
    "MAX_REQUEST_NONCE_LEN": 128,
    "MAX_PROOF_ID_LEN": 128,
    "MAX_PROVIDER_LEN": 64,
    "MAX_MODEL_LEN": 255,
    "MAX_KEY_ID_LEN": 128,
    "MAX_PROVIDER_REQUEST_ID_LEN": 255,
    "MAX_PROOF_URL_LEN": 512,
    "CONFIG_SPACE": 192,
    "PROVIDER_SIGNER_SPACE": 384,
    "RECEIPT_SPACE": 896,
    "CHALLENGE_SPACE": 352
  },
  "seeds": {
    "CONFIG_SEED": "config",
    "PROVIDER_SIGNER_SEED": "provider_signer",
    "RECEIPT_SEED": "receipt",
    "CHALLENGE_SEED": "challenge"
  },
  "enums": {
    "ProofMode": {
      "sig_log": 0,
      "sig_log_zk_reserved": 1
    },
    "AttesterType": {
      "provider": 0,
      "gateway": 1,
      "hybrid": 2
    },
    "UsageBasis": {
      "provider_reported": 0,
      "server_estimated_reserved": 1,
      "hybrid_reserved": 2,
      "tokenizer_verified_reserved": 3
    },
    "SignerStatus": {
      "inactive": 0,
      "active": 1,
      "revoked": 2
    },
    "ReceiptStatus": {
      "submitted": 0,
      "challenged": 1,
      "finalized": 2,
      "rejected": 3,
      "slashed": 4
    },
    "ChallengeStatus": {
      "open": 0,
      "responded": 1,
      "accepted": 2,
      "rejected": 3,
      "expired": 4
    },
    "ChallengeType": {
      "invalid_signature": 0,
      "signer_registry_mismatch": 1,
      "replay_nonce": 2,
      "invalid_log_inclusion": 3,
      "payload_mismatch": 4
    },
    "ResolutionCode": {
      "none": 0,
      "accepted": 1,
      "rejected": 2,
      "receipt_invalidated": 3,
      "signer_revoked": 4
    }
  },
  "accounts": {
    "Config": {
      "space": 192,
      "seeds": ["config"],
      "fields": [
        {"name": "authority", "type": "pubkey"},
        {"name": "pause_authority", "type": "pubkey"},
        {"name": "challenge_resolver", "type": "pubkey"},
        {"name": "challenge_window_seconds", "type": "i64"},
        {"name": "response_window_seconds", "type": "i64"},
        {"name": "receipt_count", "type": "u64"},
        {"name": "challenge_count", "type": "u64"},
        {"name": "is_paused", "type": "bool"},
        {"name": "phase2_enabled", "type": "bool"},
        {"name": "bump", "type": "u8"},
        {"name": "reserved", "type": {"array": ["u8", 32]}}
      ]
    },
    "ProviderSigner": {
      "space": 384,
      "seeds": ["provider_signer", "provider_code_hash", "signer_pubkey"],
      "fields": [
        {"name": "provider_code", "type": "string", "max_len": 64},
        {"name": "signer", "type": "pubkey"},
        {"name": "key_id", "type": "string", "max_len": 128},
        {"name": "attester_type_mask", "type": "u8"},
        {"name": "status", "type": "u8", "enum": "SignerStatus"},
        {"name": "valid_from", "type": "i64"},
        {"name": "valid_until", "type": "i64"},
        {"name": "metadata_hash", "type": {"array": ["u8", 32]}},
        {"name": "created_at", "type": "i64"},
        {"name": "updated_at", "type": "i64"},
        {"name": "bump", "type": "u8"},
        {"name": "reserved", "type": {"array": ["u8", 32]}}
      ]
    },
    "Receipt": {
      "space": 896,
      "seeds": ["receipt", "request_nonce_hash"],
      "fields": [
        {"name": "request_nonce", "type": "string", "max_len": 128},
        {"name": "proof_id", "type": "string", "max_len": 128},
        {"name": "provider", "type": "string", "max_len": 64},
        {"name": "model", "type": "string", "max_len": 255},
        {"name": "proof_mode", "type": "u8", "enum": "ProofMode"},
        {"name": "attester_type", "type": "u8", "enum": "AttesterType"},
        {"name": "usage_basis", "type": "u8", "enum": "UsageBasis"},
        {"name": "prompt_tokens", "type": "u64"},
        {"name": "completion_tokens", "type": "u64"},
        {"name": "total_tokens", "type": "u64"},
        {"name": "charge_atomic", "type": "u64"},
        {"name": "charge_mint", "type": "pubkey"},
        {"name": "receipt_hash", "type": {"array": ["u8", 32]}},
        {"name": "signer", "type": "pubkey"},
        {"name": "proof_url_hash", "type": {"array": ["u8", 32]}},
        {"name": "submitted_at", "type": "i64"},
        {"name": "challenge_deadline", "type": "i64"},
        {"name": "finalized_at", "type": "i64"},
        {"name": "status", "type": "u8", "enum": "ReceiptStatus"},
        {"name": "bump", "type": "u8"},
        {"name": "reserved", "type": {"array": ["u8", 64]}}
      ]
    },
    "Challenge": {
      "space": 352,
      "seeds": ["challenge", "receipt_pubkey", "challenge_type", "challenger_pubkey"],
      "fields": [
        {"name": "request_nonce", "type": "string", "max_len": 128},
        {"name": "receipt", "type": "pubkey"},
        {"name": "challenger", "type": "pubkey"},
        {"name": "challenge_type", "type": "u8", "enum": "ChallengeType"},
        {"name": "evidence_hash", "type": {"array": ["u8", 32]}},
        {"name": "response_hash", "type": {"array": ["u8", 32]}},
        {"name": "opened_at", "type": "i64"},
        {"name": "response_deadline", "type": "i64"},
        {"name": "resolved_at", "type": "i64"},
        {"name": "status", "type": "u8", "enum": "ChallengeStatus"},
        {"name": "resolution_code", "type": "u8", "enum": "ResolutionCode"},
        {"name": "bump", "type": "u8"},
        {"name": "reserved", "type": {"array": ["u8", 32]}}
      ]
    }
  },
  "instructions": [
    {
      "name": "initialize_config",
      "accounts": [
        {"name": "payer", "writable": true, "signer": true},
        {"name": "config", "writable": true},
        {"name": "system_program"}
      ],
      "args": [
        {"name": "authority", "type": "pubkey"},
        {"name": "pause_authority", "type": "pubkey"},
        {"name": "challenge_resolver", "type": "pubkey"},
        {"name": "challenge_window_seconds", "type": "i64"},
        {"name": "response_window_seconds", "type": "i64"}
      ]
    },
    {
      "name": "upsert_provider_signer",
      "accounts": [
        {"name": "authority", "signer": true},
        {"name": "config"},
        {"name": "provider_signer", "writable": true},
        {"name": "system_program"}
      ],
      "args": [
        {"name": "provider_code", "type": "string", "max_len": 64},
        {"name": "signer", "type": "pubkey"},
        {"name": "key_id", "type": "string", "max_len": 128},
        {"name": "attester_type_mask", "type": "u8"},
        {"name": "valid_from", "type": "i64"},
        {"name": "valid_until", "type": "i64"},
        {"name": "metadata_hash", "type": {"array": ["u8", 32]}}
      ]
    },
    {
      "name": "set_pause",
      "accounts": [
        {"name": "pause_authority", "signer": true},
        {"name": "config", "writable": true}
      ],
      "args": [
        {"name": "is_paused", "type": "bool"}
      ]
    },
    {
      "name": "revoke_provider_signer",
      "accounts": [
        {"name": "authority", "signer": true},
        {"name": "config"},
        {"name": "provider_signer", "writable": true}
      ],
      "args": [
        {"name": "provider_code", "type": "string", "max_len": 64},
        {"name": "signer", "type": "pubkey"}
      ]
    },
    {
      "name": "submit_receipt",
      "accounts": [
        {"name": "payer", "writable": true, "signer": true},
        {"name": "config"},
        {"name": "provider_signer"},
        {"name": "receipt", "writable": true},
        {"name": "instructions_sysvar"},
        {"name": "system_program"}
      ],
      "args": [
        {"name": "version", "type": "u8"},
        {"name": "proof_mode", "type": "u8", "enum": "ProofMode"},
        {"name": "proof_id", "type": "string", "max_len": 128},
        {"name": "request_nonce", "type": "string", "max_len": 128},
        {"name": "provider", "type": "string", "max_len": 64},
        {"name": "attester_type", "type": "u8", "enum": "AttesterType"},
        {"name": "model", "type": "string", "max_len": 255},
        {"name": "usage_basis", "type": "u8", "enum": "UsageBasis"},
        {"name": "prompt_tokens", "type": "u64"},
        {"name": "completion_tokens", "type": "u64"},
        {"name": "total_tokens", "type": "u64"},
        {"name": "charge_atomic", "type": "u64"},
        {"name": "charge_mint", "type": "pubkey"},
        {"name": "provider_request_id", "type": {"option": {"string": {"max_len": 255}}}},
        {"name": "issued_at", "type": {"option": "i64"}},
        {"name": "expires_at", "type": {"option": "i64"}},
        {"name": "http_status", "type": {"option": "u16"}},
        {"name": "latency_ms", "type": {"option": "u64"}},
        {"name": "proof_url", "type": "string", "max_len": 512},
        {"name": "receipt_hash", "type": {"array": ["u8", 32]}},
        {"name": "signer", "type": "pubkey"},
        {"name": "signature", "type": {"array": ["u8", 64]}}
      ],
      "requires_preceding_ed25519_instruction": true
    },
    {
      "name": "open_challenge",
      "accounts": [
        {"name": "challenger", "writable": true, "signer": true},
        {"name": "config"},
        {"name": "receipt", "writable": true},
        {"name": "challenge", "writable": true},
        {"name": "system_program"}
      ],
      "args": [
        {"name": "request_nonce", "type": "string", "max_len": 128},
        {"name": "challenge_type", "type": "u8", "enum": "ChallengeType"},
        {"name": "evidence_hash", "type": {"array": ["u8", 32]}}
      ]
    },
    {
      "name": "respond_challenge",
      "accounts": [
        {"name": "responder", "signer": true},
        {"name": "config"},
        {"name": "receipt"},
        {"name": "challenge", "writable": true}
      ],
      "args": [
        {"name": "request_nonce", "type": "string", "max_len": 128},
        {"name": "challenge_type", "type": "u8", "enum": "ChallengeType"},
        {"name": "challenger", "type": "pubkey"},
        {"name": "response_hash", "type": {"array": ["u8", 32]}}
      ]
    },
    {
      "name": "resolve_challenge",
      "accounts": [
        {"name": "challenge_resolver", "signer": true},
        {"name": "config"},
        {"name": "receipt", "writable": true},
        {"name": "challenge", "writable": true}
      ],
      "args": [
        {"name": "request_nonce", "type": "string", "max_len": 128},
        {"name": "challenge_type", "type": "u8", "enum": "ChallengeType"},
        {"name": "challenger", "type": "pubkey"},
        {"name": "resolution_code", "type": "u8", "enum": "ResolutionCode"}
      ]
    },
    {
      "name": "finalize_receipt",
      "accounts": [
        {"name": "caller", "signer": true},
        {"name": "config"},
        {"name": "receipt", "writable": true}
      ],
      "args": [
        {"name": "request_nonce", "type": "string", "max_len": 128}
      ]
    }
  ],
  "validation_rules": [
    "version must equal 1",
    "proof_mode must equal sig_log",
    "usage_basis must equal provider_reported",
    "total_tokens must equal prompt_tokens plus completion_tokens",
    "expires_at must be absent or greater than or equal to issued_at",
    "request_nonce must be unique",
    "canonical CBOR hash must equal receipt_hash",
    "matching ed25519 verify instruction must be present",
    "provider signer must exist, be active, and match provider plus attester_type"
  ]
}
